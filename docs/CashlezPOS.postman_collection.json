{
  "info": {
    "_postman_id": "cashlez-pos-collection",
    "name": "Cashlez POS API",
    "description": "Postman collection for Cashlez POS Service. Base URL: https://siravine.cashup.id/\n\nEnvironments:\n- envOctopus (Production): https://octopus-decoupling.cashlez.com/\n- envLionFish (ASG):       https://lionfish-decoupling.cashlez.com/\n- envOrca:                 https://orca.cashlez.com/\n- envAngelfish:            https://angelfish.cashlez.com/\n- envSword (Staging):      https://sword-decoupling.cashlez.com/\n- envTucanos:              https://tucanos.cashup.id/\n\nPOS Service uses dedicated URL: https://siravine.cashup.id/\nUpload Service uses dedicated URL: https://virellon.cashup.id/\n\nAuthN: Login via POST /pos/auth/login to get token, then set {{pos_token}} variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "pos_base_url",
      "value": "https://siravine.cashup.id",
      "type": "string",
      "description": "Base URL for POS API"
    },
    {
      "key": "upload_base_url",
      "value": "https://virellon.cashup.id",
      "type": "string",
      "description": "Base URL for Upload API"
    },
    {
      "key": "pos_token",
      "value": "",
      "type": "string",
      "description": "Bearer token dari response /pos/auth/login"
    },
    {
      "key": "product_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "category_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "transaction_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "merchant_trx_id",
      "value": "TRX-001",
      "type": "string"
    },
    {
      "key": "payment_setting_id",
      "value": "1",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{pos_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set('pos_token', jsonData.data.token);",
                  "    console.log('Token saved:', jsonData.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"your_username\",\n  \"password\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{pos_base_url}}/pos/auth/login",
              "host": [
                "{{pos_base_url}}"
              ],
              "path": [
                "pos",
                "auth",
                "login"
              ]
            },
            "description": "Login ke POS dan dapatkan token. Token akan otomatis disimpan ke variabel {{pos_token}}."
          },
          "response": [
            {
              "name": "Login Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"SUCCESS\",\n  \"message\": \"Login successful\",\n  \"data\": {\n    \"token\": \"eyJhbGciOiJIUzI1NiJ9...\"\n  }\n}"
            }
          ]
        }
      ]
    },
